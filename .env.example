# ============================================================
# TRIPPY ANTS CMS — Environment variables
# Copy to .env.local for local dev; set in Vercel for production.
# ============================================================

# --- Supabase (new project — do NOT reuse Revue keys) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Site ---
# Canonical blog URL (includes /blog path on the main Wix domain).
NEXT_PUBLIC_SITE_URL=https://www.trippyants.com/blog

# Single CMS admin — must match Supabase Auth user email exactly.
ALLOWED_CMS_EMAIL=your-admin@example.com

# Optional: on-demand revalidation webhook secret
REVALIDATE_SECRET=change-me-to-a-long-random-string
